comptime _POW5_HI = _build_pow5_hi()
comptime _POW5_LO = _build_pow5_lo()


@always_inline("nodebug")
def get_pow5(exponent: Int) -> Uint128:
    """Get 5^exponent normalized to 128 bits."""
    var idx = exponent - (-342)
    return Uint128(hi=_POW5_HI[idx], lo=_POW5_LO[idx])
